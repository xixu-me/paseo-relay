{
  "name": "paseo-relay",
  "private": true,
  "description": "Self-hosted Paseo relay.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "paseo",
    "relay",
    "cloudflare-workers",
    "durable-objects"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xixu-me/paseo-relay.git"
  },
  "bugs": {
    "url": "https://github.com/xixu-me/paseo-relay/issues"
  },
  "homepage": "https://github.com/xixu-me/paseo-relay",
  "scripts": {
    "dev": "bunx wrangler dev",
    "deploy": "bunx wrangler deploy",
    "check": "bun run typecheck && bun run test && bun run cf-typegen:check && bunx wrangler deploy --dry-run",
    "typecheck": "bun run cf-typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "bunx wrangler types",
    "cf-typegen:check": "bunx wrangler types --check",
    "oci:bundle": "bunx wrangler deploy --dry-run --outdir=dist-oci",
    "oci:build": "bun run oci:bundle && docker build -t paseo-relay:latest .",
    "oci:run": "docker run --rm -p 8080:8080 -v paseo-relay-data:/var/lib/paseo-relay/do paseo-relay:latest"
  },
  "dependencies": {
    "@getpaseo/relay": "^0.1.54"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "packageManager": "bun@1.3.12"
}
