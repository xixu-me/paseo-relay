{
  "name": "paseo-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx wrangler dev",
    "deploy": "bunx wrangler deploy",
    "check": "bun run typecheck && bun run test && bun run cf-typegen:check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "bunx wrangler types",
    "cf-typegen:check": "bunx wrangler types --check"
  },
  "dependencies": {
    "@getpaseo/relay": "^0.1.52"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.40",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.39.0"
  },
  "packageManager": "bun@1.3.12"
}
